{
  "configuracion_performance": {
    "version": "1.0.0",
    "descripcion": "Configuración para escenarios de pruebas de performance",
    "fecha_creacion": "2024-12-15",
    "autores": [
      "Antonio B. Arriagada LL.",
      "Dante Escalona Bustos",
      "Roberto Rivas Lopez"
    ]
  },
  "parametros_globales": {
    "timeout_maximo_segundos": 30,
    "timeout_navegacion_segundos": 10,
    "timeout_elemento_segundos": 5,
    "reintentos_maximo": 3,
    "espera_entre_reintentos_ms": 1000,
    "captura_screenshots_performance": false,
    "nivel_logging": "INFO"
  },
  "umbrales_performance": {
    "login": {
      "tiempo_maximo_segundos": 3,
      "tiempo_objetivo_segundos": 2,
      "descripcion": "Tiempo máximo aceptable para proceso de login"
    },
    "registro": {
      "tiempo_maximo_segundos": 5,
      "tiempo_objetivo_segundos": 3,
      "descripcion": "Tiempo máximo aceptable para registro de usuario"
    },
    "carga_pagina": {
      "tiempo_maximo_segundos": 4,
      "tiempo_objetivo_segundos": 2,
      "descripcion": "Tiempo máximo aceptable para carga de página"
    },
    "crud_crear": {
      "tiempo_maximo_segundos": 4,
      "tiempo_objetivo_segundos": 2,
      "descripcion": "Tiempo máximo para crear un producto"
    },
    "crud_listar": {
      "tiempo_maximo_segundos": 5,
      "tiempo_objetivo_segundos": 3,
      "descripcion": "Tiempo máximo para listar productos"
    },
    "crud_actualizar": {
      "tiempo_maximo_segundos": 3,
      "tiempo_objetivo_segundos": 2,
      "descripcion": "Tiempo máximo para actualizar un producto"
    },
    "crud_eliminar": {
      "tiempo_maximo_segundos": 3,
      "tiempo_objetivo_segundos": 1,
      "descripcion": "Tiempo máximo para eliminar un producto"
    },
    "busqueda": {
      "tiempo_maximo_segundos": 6,
      "tiempo_objetivo_segundos": 3,
      "descripcion": "Tiempo máximo para búsqueda de productos"
    },
    "navegacion": {
      "tiempo_maximo_segundos": 2,
      "tiempo_objetivo_segundos": 1,
      "descripcion": "Tiempo máximo para navegación entre páginas"
    }
  },
  "escenarios_performance": {
    "login_performance": {
      "nombre": "Performance del proceso de login",
      "descripcion": "Validar que el login se complete en tiempo aceptable",
      "categoria": "autenticacion",
      "prioridad": "alta",
      "tags": ["@Performance", "@Login", "@Critico"],
      "umbral_segundos": 3,
      "datos_prueba": {
        "usuario_valido": {
          "email": "performance@test.com",
          "password": "PerformanceTest123!"
        }
      },
      "validaciones": [
        "Tiempo de respuesta <= 3 segundos",
        "Sin errores JavaScript",
        "Redirección correcta post-login"
      ]
    },
    "registro_performance": {
      "nombre": "Performance del proceso de registro",
      "descripcion": "Validar que el registro se complete en tiempo aceptable",
      "categoria": "registro",
      "prioridad": "alta",
      "tags": ["@Performance", "@Registro", "@Critico"],
      "umbral_segundos": 5,
      "datos_prueba": {
        "usuario_nuevo": {
          "nombre": "Usuario",
          "apellido": "Performance",
          "email": "performance{timestamp}@test.com",
          "password": "PerformanceTest123!"
        }
      },
      "validaciones": [
        "Tiempo de respuesta <= 5 segundos",
        "Validaciones cliente-servidor",
        "Confirmación de registro exitoso"
      ]
    },
    "crud_productos_performance": {
      "nombre": "Performance de operaciones CRUD",
      "descripcion": "Validar performance de crear, leer, actualizar y eliminar productos",
      "categoria": "crud",
      "prioridad": "media",
      "tags": ["@Performance", "@CRUD", "@GestionProductos"],
      "operaciones": {
        "crear": {
          "umbral_segundos": 4,
          "datos_producto": {
            "nombre": "Producto Performance {timestamp}",
            "descripcion": "Producto para pruebas de performance",
            "precio": 99.99,
            "categoria": "GENERAL",
            "stock": 100
          }
        },
        "listar": {
          "umbral_segundos": 5,
          "cantidad_registros_esperados": "variable",
          "filtros_aplicables": ["categoria", "precio", "nombre"]
        },
        "actualizar": {
          "umbral_segundos": 3,
          "campos_actualizar": ["nombre", "descripcion", "precio", "stock"]
        },
        "eliminar": {
          "umbral_segundos": 3,
          "validar_eliminacion": true
        }
      }
    },
    "carga_paginas_performance": {
      "nombre": "Performance de carga de páginas",
      "descripcion": "Validar tiempo de carga de las principales páginas",
      "categoria": "navegacion",
      "prioridad": "media",
      "tags": ["@Performance", "@Navegacion", "@UX"],
      "paginas": {
        "inicio": {
          "url": "/",
          "umbral_segundos": 4,
          "elementos_criticos": ["header", "navigation", "main-content"]
        },
        "login": {
          "url": "/login",
          "umbral_segundos": 3,
          "elementos_criticos": ["login-form", "email-input", "password-input"]
        },
        "registro": {
          "url": "/registro",
          "umbral_segundos": 4,
          "elementos_criticos": ["registro-form", "campos-obligatorios"]
        },
        "productos": {
          "url": "/productos",
          "umbral_segundos": 5,
          "elementos_criticos": ["tabla-productos", "filtros", "paginacion"]
        },
        "dashboard": {
          "url": "/dashboard",
          "umbral_segundos": 4,
          "elementos_criticos": ["widgets", "estadisticas", "navegacion"]
        }
      }
    },
    "busqueda_performance": {
      "nombre": "Performance de funcionalidad de búsqueda",
      "descripcion": "Validar performance de búsquedas y filtros",
      "categoria": "busqueda",
      "prioridad": "media",
      "tags": ["@Performance", "@Busqueda", "@Filtros"],
      "tipos_busqueda": {
        "busqueda_simple": {
          "umbral_segundos": 6,
          "terminos_prueba": ["producto", "test", "categoria", "precio"],
          "validaciones": ["resultados_relevantes", "tiempo_respuesta"]
        },
        "busqueda_avanzada": {
          "umbral_segundos": 8,
          "filtros_combinados": {
            "categoria": ["ELECTRODOMESTICOS", "ELECTRONICOS", "GENERAL"],
            "rango_precio": {"min": 10.0, "max": 1000.0},
            "disponibilidad": ["en_stock", "agotado"]
          },
          "validaciones": ["precision_filtros", "ordenamiento", "paginacion"]
        },
        "busqueda_autocompletado": {
          "umbral_segundos": 2,
          "caracteres_minimos": 3,
          "sugerencias_maximas": 10,
          "validaciones": ["relevancia_sugerencias", "velocidad_respuesta"]
        }
      }
    }
  },
  "configuracion_navegador": {
    "performance_settings": {
      "disable_images": false,
      "disable_css": false,
      "disable_javascript": false,
      "network_throttling": false,
      "cache_disabled": false,
      "user_agent": "Mozilla/5.0 (Performance Testing Bot)"
    },
    "metricas_capturar": [
      "page_load_time",
      "dom_content_loaded",
      "first_contentful_paint",
      "largest_contentful_paint",
      "cumulative_layout_shift",
      "first_input_delay"
    ]
  },
  "datos_prueba_performance": {
    "usuarios_concurrentes": {
      "usuario_performance_1": {
        "email": "perf1@test.com",
        "password": "Performance123!",
