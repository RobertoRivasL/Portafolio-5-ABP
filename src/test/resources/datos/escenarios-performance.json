  "reportes_performance": {
    "configuracion": {
      "generar_graficos": true,
      "incluir_metricas_detalladas": true,
      "formato_salida": ["json", "html", "csv"],
      "directorio_salida": "reportes/performance"
    },
    "metricas_incluir": [
      "tiempo_promedio_respuesta",
      "tiempo_maximo_respuesta",
      "tiempo_minimo_respuesta",
      "percentil_95",
      "percentil_99",
      "tasa_exito",
      "errores_por_tipo",
      "tendencia_temporal"
    ],
    "alertas": {
      "umbral_degradacion_porcentaje": 20,
      "notification_webhook": null,
      "email_alertas": []
    }
  },
  "escenarios_carga": {
    "carga_ligera": {
      "descripcion": "Prueba con carga mínima del sistema",
      "usuarios_simultaneos": 1,
      "duracion_minutos": 5,
      "ramp_up_segundos": 0
    },
    "carga_moderada": {
      "descripcion": "Prueba con carga moderada del sistema",
      "usuarios_simultaneos": 5,
      "duracion_minutos": 10,
      "ramp_up_segundos": 30
    },
    "carga_alta": {
      "descripcion": "Prueba con alta carga del sistema",
      "usuarios_simultaneos": 20,
      "duracion_minutos": 15,
      "ramp_up_segundos": 60
    }
  },
  "validaciones_automaticas": {
    "reglas_performance": [
      {
        "nombre": "Tiempo de respuesta aceptable",
        "condicion": "tiempo_respuesta <= umbral_definido",
        "accion_fallo": "marcar_como_fallido"
      },
      {
        "nombre": "Sin errores JavaScript",
        "condicion": "errores_javascript == 0",
        "accion_fallo": "capturar_logs_consola"
      },
      {
        "nombre": "Elementos críticos cargados",
        "condicion": "elementos_criticos.todos_visibles",
        "accion_fallo": "capturar_screenshot"
      },
      {
        "nombre": "Memoria estable",
        "condicion": "uso_memoria < 100MB",
        "accion_fallo": "registrar_uso_recursos"
      }
    ]
  },
