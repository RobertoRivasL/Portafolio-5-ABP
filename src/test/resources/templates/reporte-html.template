    <!-- Estilos adicionales para tooltips -->
    <style>
        .tooltip {
            position: absolute;
            background: #333;
            color: white;
            padding: 8px 12px;
            border-radius: 4px;
            font-size: 0.8em;
            z-index: 1000;
            pointer-events: none;
            white-space: nowrap;
            box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        }

        .tooltip::after {
            content: '';
            position: absolute;
            top: 100%;
            left: 50%;
            margin-left: -5px;
            border: 5px solid transparent;
            border-top-color: #333;
        }

        /* Estilos para elementos interactivos */
        .interactive-element {
            cursor: pointer;
            transition: var(--transition);
        }

        .interactive-element:hover {
            opacity: 0.8;
            transform: scale(1.02);
        }

        /* Indicadores de carga */
        .loading {
            display: none;
            text-align: center;
            padding: 20px;
        }

        .loading.active {
            display: block;
        }

        .spinner {
            border: 3px solid #f3f3f3;
            border-top: 3px solid var(--primary-color);
            border-radius: 50%;
            width: 40px;
            height: 40px;
            animation: spin 1s linear infinite;
            margin: 0 auto;
        }

        @keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>

    <script>
        // Funciones adicionales para mejorar la interactividad

        // Función para actualizar estadísticas dinámicamente
        function actualizarEstadisticas() {
            // Esta función se puede usar para actualizar stats en tiempo real
            console.log('Actualizando estadísticas...');
        }

        // Función para generar gráficos simples con ASCII
        function generarGraficoBarras(datos) {
            let grafico = '';
            const maxValor = Math.max(...datos.map(d => d.valor));

            datos.forEach(item => {
                const porcentaje = (item.valor / maxValor) * 100;
                const barras = '█'.repeat(Math.round(porcentaje / 5));
                grafico += `${item.nombre.padEnd(15)} |${barras} ${item.valor}\n`;
            });

            return grafico;
        }

        // Función para validar datos del reporte
        function validarDatos() {
            const elementos = document.querySelectorAll('[data-validate]');
            let errores = [];

            elementos.forEach(elemento => {
                const valor = elemento.textContent.trim();
                if (!valor || valor === '{{' + elemento.getAttribute('data-validate') + '}}') {
                    errores.push(elemento.getAttribute('data-validate'));
                }
            });

            if (errores.length > 0) {
                console.warn('Datos faltantes en el template:', errores);
            }

            return errores.length === 0;
        }

        // Función para mejorar la accesibilidad
        function mejorarAccesibilidad() {
            // Agregar roles ARIA
            document.querySelectorAll('.data-table').forEach(tabla => {
                tabla.setAttribute('role', 'table');
            });

            // Mejorar navegación por teclado
            document.querySelectorAll('.expandable-header').forEach(header => {
                header.setAttribute('tabindex', '0');
                header.addEventListener('keydown', function(e) {
                    if (e.key === 'Enter' || e.key === ' ') {
                        e.preventDefault();
                        this.click();
                    }
                });
            });
        }

        // Inicializar funciones adicionales cuando el DOM esté listo
        document.addEventListener('DOMContentLoaded', function() {
            validarDatos();
            mejorarAccesibilidad();
        });
    </script>
